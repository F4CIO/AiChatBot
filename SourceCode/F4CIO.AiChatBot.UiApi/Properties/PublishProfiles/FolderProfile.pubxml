<?xml version="1.0" encoding="utf-8"?>
<!--
  Visual Studio: right-click the UiApi project -> Publish -> FolderProfile.
  Produces the same output as publish-api.bat:
  ..\Published\F4CIO.AiChatBot.UiApi  (sibling of SourceCode), self-contained win-x64.
-->
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishDir>..\..\Published\F4CIO.AiChatBot.UiApi\</PublishDir>
  </PropertyGroup>
</Project>
