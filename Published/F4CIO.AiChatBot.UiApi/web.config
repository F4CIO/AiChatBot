<?xml version="1.0" encoding="utf-8"?>
<!--
  ASP.NET Core in-process hosting under IIS.
  dotnet publish injects/refreshes the <aspNetCore> and <handlers> entries; the
  custom <rewrite><rules><clear /> is preserved.

  Why the <clear />: this API runs as an IIS child application in its own app
  pool, under a parent SPA site that has URL Rewrite SPA-fallback rules. Any
  inherited rewrite rule that rewrites a request to the SPA's /index.html sends
  it into a DIFFERENT app pool, which IIS rejects with HTTP 403.18. Clearing
  inherited rewrite rules here guarantees API requests are never rewritten.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <rewrite>
        <rules>
          <clear />
        </rules>
      </rewrite>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath=".\F4CIO.AiChatBot.UiApi.exe" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
